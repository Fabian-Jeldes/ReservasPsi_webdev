# Públicas (VITE_* se incluyen en el bundle del cliente — nunca secretos OAuth aquí).

# PostHog (opcional; si está vacío, no se inicializa)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Ghost Content API (solo lectura de posts; la clave es de solo contenido, igual revócala si filtra)
VITE_GHOST_CONTENT_API_URL=https://tu-ghost.tld/ghost/api/content
VITE_GHOST_CONTENT_API_KEY=

# Tu backend (KYC, citas, Doctoralia proxy)
VITE_API_BASE_URL=

# Base URL del servicio de disponibilidad (Calendar): GET {base}/availability → { "days": [...] }
# Vacío = mock local. La Google Calendar API y las keys van en ese backend, no aquí.
VITE_CALENDAR_API_BASE_URL=
